# LLM Provider API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Comma-separated list of allowed emails (leave empty to allow all verified Google emails)
ALLOWED_EMAILS=you@gmail.com,friend@gmail.com

# Optional: shared secret for server-to-server auth (bypasses Google token validation and email check)
PROXY_SECRET=
